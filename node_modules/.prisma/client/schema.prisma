generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  engineer
  technician
  operator
}

enum AttractionStatus {
  operational
  maintenance
  inactive
  inspection
}

enum PlanType {
  power_diagram
  control_diagram
  single_line
  plc_diagram
  communication
  grounding
  lighting
  mechanical
  hydraulic
  pneumatic
}

enum PlanStatus {
  approved
  draft
  review
  obsolete
}

enum MaintenanceType {
  preventive
  corrective
  predictive
  inspection
}

enum MaintenanceStatus {
  completed
  in_progress
  scheduled
  cancelled
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole
  department   String
  avatar       String?
  active       Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  authoredPlans ElectricalPlan[] @relation("PlanAuthor")
  comments      Comment[]
}

model Attraction {
  id               String           @id @default(cuid())
  name             String
  code             String           @unique
  area             String
  status           AttractionStatus @default(operational)
  description      String
  image            String?
  capacity         Int?
  heightM          Float?
  durationMin      Int?
  manufacturer     String?
  model            String?
  yearInstalled    Int?
  installedPowerKw Float?
  operatingVoltage Json?
  controlVoltageV  Int?
  frequencyHz      Int?
  protectionIp     String?
  technicalSpecs   Json?
  lastMaintenance  DateTime?
  nextMaintenance  DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  plans       ElectricalPlan[]
  maintenance MaintenanceRecord[]
}

model ElectricalPlan {
  id             String     @id @default(cuid())
  attractionId   String
  planNumber     String     @unique
  title          String
  type           PlanType
  status         PlanStatus @default(draft)
  currentVersion String
  authorId       String?
  reviewer       String?
  approver       String?
  fileUrl        String
  fileSizeKb     Int
  pages          Int        @default(1)
  tags           String[]
  description    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  attraction Attraction     @relation(fields: [attractionId], references: [id])
  author     User?          @relation("PlanAuthor", fields: [authorId], references: [id])
  revisions  PlanRevision[]
  comments   Comment[]
}

model PlanRevision {
  id          String   @id @default(cuid())
  planId      String
  version     String
  author      String
  description String
  fileUrl     String
  fileSizeKb  Int
  createdAt   DateTime @default(now())

  plan ElectricalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  planId    String
  userId    String
  content   String
  resolved  Boolean  @default(false)
  pageRef   Int?
  createdAt DateTime @default(now())

  plan ElectricalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id])
}

model MaintenanceRecord {
  id            String            @id @default(cuid())
  attractionId  String
  type          MaintenanceType
  status        MaintenanceStatus
  date          DateTime
  technician    String
  description   String
  durationHours Float?
  partsReplaced String[]
  observations  String?
  nextAction    String?
  createdAt     DateTime          @default(now())

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
}
